def get_the_value(pizza_flavours, pizza_prices):     
    total_value = 0                                  #It shows the total value of the order
    for flavour, quantity in pizza_flavours.items():
        if flavour in pizza_prices:
            total_value += quantity * pizza_prices[flavour]
    return total_value

